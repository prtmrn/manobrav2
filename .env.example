# ─── Supabase ────────────────────────────────────────────────────────────────
# Trouvez ces valeurs dans : Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre-anon-key-ici

# (Optionnel) Clé service role — uniquement côté serveur
# SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key-ici

# ─── Google Maps (Carte interactive /map) ────────────────────────────────────
# Activez l'API "Maps JavaScript API" dans Google Cloud Console
# https://console.cloud.google.com/apis/library/maps-backend.googleapis.com
NEXT_PUBLIC_GOOGLE_MAPS_KEY=votre-maps-javascript-api-key-ici

# Map ID (requis pour AdvancedMarker) — créez-en un dans Cloud Console
# https://console.cloud.google.com/google/maps-apis/studio/maps
# En développement, "DEMO_MAP_ID" peut être utilisé (fonctionnalités limitées)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# ─── Google Maps Geocoding (Onboarding artisan) ──────────────────────────
# Activez l'API "Geocoding API" dans Google Cloud Console
# Peut être la même clé que NEXT_PUBLIC_GOOGLE_MAPS_KEY si les deux APIs sont activées
# SÉCURITÉ : clé serveur uniquement — ne PAS ajouter le préfixe NEXT_PUBLIC_
GOOGLE_MAPS_GEOCODING_KEY=votre-geocoding-api-key-ici

# ─── Emails transactionnels (Brevo) ──────────────────────────────────────────
# Créez un compte sur https://www.brevo.com et obtenez votre clé API :
# Mon compte > SMTP & API > Clés API
BREVO_API_KEY=votre-brevo-api-key-ici

# L'adresse email d'expédition (doit être vérifiée dans Brevo)
BREVO_SENDER_EMAIL=noreply@votre-domaine.fr

# Le nom affiché comme expéditeur
BREVO_SENDER_NAME=Nom de votre plateforme

# ─── URLs & Variables serveur ─────────────────────────────────────────────────
# URL publique de votre site (sans slash final)
# En local : http://localhost:3000  /  En prod : https://votre-domaine.fr
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase Service Role (serveur uniquement — NE PAS exposer côté client) ─
# Trouvez cette valeur dans : Supabase Dashboard > Settings > API > service_role
# Cette clé bypasse les RLS — utilisez-la UNIQUEMENT dans les API routes serveur
SUPABASE_SERVICE_ROLE_KEY=votre-service-role-key-ici

# ─── Stripe Connect ───────────────────────────────────────────────────────────
# Clé secrète (Dashboard Stripe > Développeurs > Clés API)
# En test : sk_test_xxx  /  En prod : sk_live_xxx
STRIPE_SECRET_KEY=sk_test_votre-cle-secrete-stripe

# Clé publique (côté client — préfixe pk_)
# En test : pk_test_xxx  /  En prod : pk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_votre-cle-publique-stripe

# Clé webhook (Dashboard Stripe > Développeurs > Webhooks > Signing secret)
# Requis pour vérifier les événements Stripe entrants
STRIPE_WEBHOOK_SECRET=whsec_votre-webhook-secret
